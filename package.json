    "oxfmt": "^0.36.0",
    "oxlint": "~1.51.0",
    "postcss": "^8.5.6",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
