    "pinia": "^3.0.4",
    "quasar": "^2.18.6",
    "vue": "^3.5.29",
    "vue-i18n": "11.4.5",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.10.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "4.1.8",
    "@vue/eslint-config-prettier": "^10.2.0",
