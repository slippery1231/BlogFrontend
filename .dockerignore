# =============================================================================
# Docker 建構忽略檔案
# 排除不必要的檔案和目錄，減少建構上下文大小，提升建構速度
# =============================================================================

# Node.js 相關檔案
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn

# 建構輸出目錄
dist/
build/
.output/

# 版本控制系統
.git/
.gitignore
.gitattributes

# IDE 和編輯器設定
.vscode/
.idea/
*.swp
*.swo
*~

# 作業系統產生的檔案
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 日誌檔案
logs/
*.log

# 快取目錄
.cache/
.parcel-cache/

# 測試相關檔案
coverage/
.nyc_output/

# 文件和說明檔案
README.md
CHANGELOG.md
LICENSE
*.md

# CI/CD 相關檔案
.github/
.gitlab-ci.yml

# Docker 相關檔案（避免遞迴）
Dockerfile*
docker-compose*.yml
.dockerignore

# 臨時檔案和備份
*.tmp
*.temp
*.bak
*.backup

# 壓縮檔案
*.zip
*.tar
*.tar.gz
*.rar

# 環境變數檔案（避免將敏感資訊包含在映像中）
.env
